<!DOCTYPE html>
<html lang="fr">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulaire de l'Opération</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 30px;
            background-color: #f5f5f5;
        }

        h1, h2 {
            color: #003366;
        }

        form {
            background-color: #ffffff;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            max-width: 900px;
            margin: auto;
        }

        label {
            display: block;
            margin-top: 15px;
            font-weight: bold;
        }

        input, textarea, select {
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            border: 1px solid #ccc;
            border-radius: 8px;
            box-sizing: border-box;
        }

        button {
            margin-top: 20px;
            padding: 12px 20px;
            background-color: #0077cc;
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 16px;
        }

        button:hover {
            background-color: #005fa3;
        }

        .progress-container {
            width: 100%;
            background-color: #ddd;
            border-radius: 10px;
            overflow: hidden;
            margin: 20px auto;
            max-width: 900px;
        }

        .progress-bar {
            height: 25px;
            background-color: #4CAF50;
            width: 0%;
            text-align: center;
            color: white;
            line-height: 25px;
            transition: width 0.3s ease;
        }

        .logo-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .logo-container img {
            width: 150px;
        }

        .progress-container {
    position: sticky;
    top: 0;
    width: 100%;
    height: 30px;
    background-color: #e0e0e0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}

        /* Validation dynamique */
        input.touched:invalid,
        select.touched:invalid,
        textarea.touched:invalid {
            border: 2px solid red;
        }

        input.touched:valid,
        select.touched:valid,
        textarea.touched:valid {
            border: 2px solid green;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Ajout de la classe 'touched' pour validation dynamique
            document.querySelectorAll('input, select, textarea').forEach(field => {
                field.addEventListener('blur', () => {
                    field.classList.add('touched');
                });
            });

            // Formatage du code
            window.formatCode = function(input) {
                input.value = input.value.toUpperCase().replace(/\s+/g, '');
            }

            // Confirmation avant soumission
            const form = document.getElementById('formOperation');
            form.addEventListener('submit', function (e) {
                if (!confirm("❓ Voulez-vous vraiment soumettre ce formulaire ?")) {
                    e.preventDefault();
                } else {
                    alert("✅ Formulaire soumis avec succès !");
                }
            });

            // Barre de progression
            const progressBar = document.getElementById('progressBar');
            const fields = form.querySelectorAll('input, textarea, select');

            function updateProgress() {
                let filled = 0;
                fields.forEach(field => {
                    if (field.type !== "submit" && field.offsetParent !== null) {
                        if (field.value.trim() !== "") {
                            filled++;
                        }
                    }
                });

                const percent = Math.round((filled / fields.length) * 100);
                progressBar.style.width = percent + '%';
                progressBar.innerText = percent + '%';
            }

            fields.forEach(field => {
                field.addEventListener('input', updateProgress);
                field.addEventListener('change', updateProgress);
            });

            updateProgress(); // Initialiser au chargement
        });
    </script>
</head>
